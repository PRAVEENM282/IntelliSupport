OPENAI_API_KEY=sk-your-openai-api-key

# PostgreSQL settings (used by docker-compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=intellisupport

# App reads this — docker-compose overrides it for containers
DATABASE_URL=postgresql://postgres:changeme@localhost:5433/intellisupport

# Model settings
EMBEDDING_MODEL=text-embedding-3-small
GENERATION_MODEL=gpt-4o-mini
CHUNK_SIZE=512
CHUNK_OVERLAP=50
HYBRID_ALPHA=0.7
TOP_K=5

# Port mapping
APP_PORT=8000
DB_PORT=5433
